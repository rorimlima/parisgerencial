# ====================================================
# PARIS DAKAR GERENCIAL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ====================================================

# ── Firebase (banco de dados principal) ──────────────
# Obtenha no Console Firebase > Configurações do Projeto
VITE_FIREBASE_API_KEY="sua-api-key-aqui"
VITE_FIREBASE_AUTH_DOMAIN="paris-dakar-gerencial.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="paris-dakar-gerencial"
VITE_FIREBASE_STORAGE_BUCKET="paris-dakar-gerencial.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="seu-sender-id"
VITE_FIREBASE_APP_ID="seu-app-id"

# ── Aplicação ─────────────────────────────────────────
VITE_APP_NAME="Paris Dakar Gerencial"
VITE_APP_URL="http://localhost:3000"

# ── Segurança API (servidor) ──────────────────────────
API_SECRET_KEY="pdg_secret_key_paris_dakar_2026"
VITE_API_SECRET_KEY="pdg_secret_key_paris_dakar_2026"

